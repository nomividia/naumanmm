{
    "name": "morgan-and-mallet-crm",
    "version": "0.0.1",
    "description": "Morgan And Mallet",
    "scripts": {
        "ng": "ng",
        "open-back-home": "wait-on http-get://localhost:3037/swagger && open-cli http://localhost:3037/swagger",
        "debug-back-cmd": "cross-env TZ=utc ts-node-dev --respawn --no-notify --inspect --no-deps --transpile-only --project back/tsconfig.json back/main.ts",
        "debug-back-cmd-old": "cross-env TS_NODE_PROJECT=back/tsconfig.json nodemon --verbose --config nodemon-debug.json",
        "start-back-cmd": "cross-env TZ=utc NODE_ENV=development ts-node-dev --respawn --no-notify --no-deps --transpile-only --project back/tsconfig.json back/main.ts",
        "start": "dist/back/main.js",
        "start:local": "ts-node -r tsconfig-paths/register back/src/main.ts",
        "start:back": "npm run start:back:dev",
        "start:back:dev": "npm run start-back-cmd",
        "start:back:prod": "cross-env NODE_ENV=production npm run start-back-cmd",
        "start:front": "ng serve --port=4243 -o",
        "start:prod": "APP_ENV=production&& node dist/server",
        "debug:back-old": "concurrently \"npm run debug-back-cmd-old\" \"npm run open-back-home\"",
        "debug:back": "concurrently \"npm run debug-back-cmd\" \"npm run open-back-home\"",
        "lint:server": "tslint -p tsconfig.json -c tslint.json",
        "lint:front": "ng lint",
        "build:front": "ng build",
        "build:front-prod": "ng build --configuration=production",
        "build:front-prod-with-ssr": "ng build --configuration=production && ng run morgan-and-mallet-crm:server:production",
        "build:front-val": "ng build --configuration=val",
        "build:front-val-with-ssr": "ng build --configuration=val && ng run morgan-and-mallet-crm:server:val",
        "build:front-dev": "ng build && ng run morgan-and-mallet-crm:server",
        "build:prod": "ts-node --project ./tools/tools.tsconfig.json tools/build.ts",
        "build:val": "ts-node --project ./tools/tools.tsconfig.json tools/build.ts val",
        "build:back": "tsc --project back/tsconfig.json",
        "test:front": "ng test",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "test:back": "ts-node --project ./back/tsconfig.test.json node_modules/jasmine/bin/jasmine --config=jasmine.json",
        "clean-before-build": "rimraf dist",
        "copy-files-after-build": "ts-node --project ./tools/tools.tsconfig.json ./tools/copy-files-after-build.ts",
        "e2e": "ng e2e",
        "gcloud": "rimraf dist && tsc && gcloud app deploy --project=trametal-gestion",
        "nswag-generate-client": "ts-node --project ./tools/tools.tsconfig.json ./tools/nswag-generate-client.ts",
        "generate-jwt-secret": "node -e \"console.log(require('crypto').randomBytes(64).toString('base64'));\"",
        "generate-web-push-vapid-keys": "web-push generate-vapid-keys [--json]",
        "package-application": "ts-node --project ./tools/tools.tsconfig.json tools/package-application.ts",
        "test-split-csv": "cross-env NODE_OPTIONS='--max-old-space-size=8196' ts-node --project ./tools/tools.tsconfig.json tools/split-csv.ts '/Users/davidkessas/Dev/morgan-mallet-crm/back/import-data/form_data_20220329-4 copy 9.csv'",
        "split-csv": "cross-env NODE_OPTIONS='--max-old-space-size=8196' ts-node --project ./tools/tools.tsconfig.json tools/split-csv.ts",
        "split-all-csv-files": "cross-env NODE_OPTIONS='--max-old-space-size=8196' ts-node --project ./tools/tools.tsconfig.json tools/split-all-csv-files.ts",
        "test-country-data": "ts-node --project ./tools/tools.tsconfig.json ./tools/test-country-data.ts",
        "create-migration": "ts-node --project ./tools/tools.tsconfig.json tools/create-migration.ts",
        "server-migration": "ts-node --project ./tools/tools.tsconfig.json tools/server-migration.ts",
        "run-migration": "ts-node --project ./tools/tools.tsconfig.json tools/run-migration.ts",
        "revert-migration": "ts-node --project ./tools/tools.tsconfig.json tools/revert-migration.ts"
    },
