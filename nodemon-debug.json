{
  "watch": [
    "./back"
  ],
  "ext": "ts",
  "ignore": [
    "./back/**/*.spec.ts",
    "./back/**/*.log",
    "./back/**/*.pdf",
    "./back/**/*.jpg",
    "./back/**/*.xlsx",
    "./back/**/*.xlsm"
  ],
  "delay": "700",
  "exec": "kill-port 9229 && node --inspect -r ts-node/register back/main.ts"
}