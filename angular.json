{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "morgan-and-mallet-crm": {
      "root": "",
      "sourceRoot": "front/src",
      "projectType": "application",
      "prefix": "app",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/browser-build",
            "index": "front/src/index.html",
            "main": "front/src/main.ts",
            "polyfills": "front/src/polyfills.ts",
            "tsConfig": "front/src/tsconfig.app.json",
            "assets": [
              "front/src/favicon.ico",
              "front/src/assets",
              "front/src/manifest.json",
              {
                "glob": "**/*",
                "input": "node_modules/ng2-pdfjs-viewer/pdfjs",
                "output": "/assets/pdfjs"
              }
            ],
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/deeppurple-amber.css",
              "./node_modules/quill/dist/quill.bubble.css",
              "./node_modules/quill/dist/quill.snow.css",
              "./node_modules/swiper/swiper.min.css",
              "./node_modules/swiper/modules/navigation/navigation.min.css",
              "./node_modules/swiper/modules/pagination/pagination.min.css",
              "./node_modules/swiper/modules/lazy/lazy.min.css",
              "front/src/styles.scss",
              "front/src/theme.scss"
            ],
            "scripts": [],
            "allowedCommonJsDependencies": [
              "nextalys-js-helpers",
              "@firebase/app",
              "firebase/app",
              "@firebase/auth",
              "@firebase/database",
              "jwt-decode",
              "cronstrue",
              "socket.io-client"
            ],
            "vendorChunk": true,
            "extractLicenses": false,
            "buildOptimizer": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "front/src/environments/environment.dev.ts",
                  "with": "front/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ],
              "serviceWorker": true,
              "ngswConfigPath": "front/src/ngsw-config.json"
            },
            "val": {
              "fileReplacements": [
                {
                  "replace": "front/src/environments/environment.dev.ts",
                  "with": "front/src/environments/environment.val.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ],
              "serviceWorker": true,
              "ngswConfigPath": "front/src/ngsw-config.json"
            }
          },
          "defaultConfiguration": ""
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "morgan-and-mallet-crm:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "morgan-and-mallet-crm:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "morgan-and-mallet-crm:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "front/src/test.ts",
            "polyfills": "front/src/polyfills.ts",
            "tsConfig": "front/src/tsconfig.spec.json",
            "karmaConfig": "front/src/karma.conf.js",
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/deeppurple-amber.css",
              "front/src/styles.scss",
              "front/src/theme.scss"
            ],
            "scripts": [],
            "assets": [
              "front/src/favicon.ico",
              "front/src/assets",
              "front/src/manifest.json"
            ]
          }
        },
        "server": {
          "builder": "@angular-devkit/build-angular:server",
          "options": {
            "outputPath": "dist/server",
            "main": "front/src/main.server.ts",
            "tsConfig": "front/src/tsconfig.server.json",
            "sourceMap": true,
            "optimization": false
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "front/src/environments/environment.dev.ts",
                  "with": "front/src/environments/environment.prod.ts"
                }
              ],
              "bundleDependencies": false
            },
            "val": {
              "fileReplacements": [
                {
                  "replace": "front/src/environments/environment.dev.ts",
                  "with": "front/src/environments/environment.val.ts"
                }
              ],
              "bundleDependencies": false
            }
          },
          "defaultConfiguration": ""
        }
      }
    },
    "morgan-and-mallet-crm-e2e": {
      "root": "front/e2e/",
      "projectType": "application",
      "prefix": "",
      "architect": {
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "front/e2e/protractor.conf.js",
            "devServerTarget": "morgan-and-mallet-crm:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "morgan-and-mallet-crm:serve:production"
            }
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}